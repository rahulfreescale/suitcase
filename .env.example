# ===========================================================================
#  Copy to .env and fill in.  Local-dev defaults are pre-filled where safe.
# ===========================================================================

# ---- Runtime profile -------------------------------------------------------
# local  -> OpenSearch(docker) + DynamoDB-Local + Postgres(docker) + DuckDB
# aws    -> managed OpenSearch + DynamoDB + RDS + Athena/Glue/S3
DEPLOY_PROFILE=local

# ---- AWS / Bedrock ---------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# For local dev with DynamoDB-Local / MinIO, dummy creds are fine:
# AWS_ACCESS_KEY_ID=local
# AWS_SECRET_ACCESS_KEY=local

# ---- Models (litellm model strings) ----------------------------------------
# Primary first, then fallbacks (comma-separated). Tried left to right.
# litellm reads provider keys (OPENAI_API_KEY / ANTHROPIC_API_KEY) from here.
#
# >>> RECOMMENDED if you have Anthropic + OpenAI (no AWS needed for models) <<<
# Claude does the reasoning; OpenAI does embeddings (Anthropic has NO embeddings API).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL_CHAIN=anthropic/claude-3-5-sonnet-20241022,gpt-4o
LLM_FAST_MODEL=anthropic/claude-3-5-haiku-20241022
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
LLM_NUM_RETRIES=2
# (Swap the model strings for whatever your accounts have access to.)

# --- Alternative: AWS Bedrock (the "AWS-faithful" default) ---
# LLM_MODEL_CHAIN=bedrock/anthropic.claude-3-5-sonnet-20240620-v1:0,gpt-4o-mini
# LLM_FAST_MODEL=bedrock/anthropic.claude-3-haiku-20240307-v1:0
# EMBED_MODEL=bedrock/amazon.titan-embed-text-v2:0
# EMBED_DIM=1024

# --- Alternative: OpenAI only ---
# LLM_MODEL_CHAIN=gpt-4o,gpt-4o-mini
# LLM_FAST_MODEL=gpt-4o-mini
# EMBED_MODEL=text-embedding-3-small
# EMBED_DIM=1536

# --- Alternative: ZERO-CLOUD with Ollama (nothing leaves your machine) ---
# `ollama pull llama3.1` and `ollama pull nomic-embed-text` first, then:
# LLM_MODEL_CHAIN=ollama/llama3.1
# LLM_FAST_MODEL=ollama/llama3.1
# EMBED_MODEL=ollama/nomic-embed-text
# EMBED_DIM=768
# OLLAMA_API_BASE=http://localhost:11434

# ---- OpenSearch ------------------------------------------------------------
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USE_SSL=false
OPENSEARCH_USE_AWS_AUTH=false          # true for Amazon OpenSearch Service
OPENSEARCH_INDEX=suitcase-guides
OPENSEARCH_USER=admin                  # local only
OPENSEARCH_PASSWORD=Admin123!          # local only

# ---- DynamoDB (app-level state) --------------------------------------------
DYNAMODB_TABLE=suitcase-app-state
DYNAMODB_ENDPOINT=http://localhost:8000   # leave blank for real AWS

# ---- Postgres (LangGraph checkpointer) -------------------------------------
POSTGRES_DSN=postgresql://suitcase:suitcase@localhost:5432/suitcase

# ---- Structured store ------------------------------------------------------
STRUCTURED_BACKEND=local               # local | athena
# DuckDB (local) reads this CSV directly:
LOCAL_STUDIES_CSV=data/sample_reports/studies.csv
# Athena (aws):
ATHENA_DATABASE=suitcase
ATHENA_TABLE=studies
ATHENA_WORKGROUP=primary
ATHENA_OUTPUT_S3=s3://your-athena-results-bucket/output/
S3_DATA_LAKE=s3://your-data-lake-bucket/studies/

# ---- Reranker --------------------------------------------------------------
RERANK_BACKEND=cross_encoder           # cross_encoder | none
RERANK_MODEL=BAAI/bge-reranker-large

# ---- Retrieval knobs (match the article) -----------------------------------
EXPANSION_N=5
HYBRID_CANDIDATES=20
RERANK_TOP_K=7
SEMANTIC_WEIGHT=0.7
KEYWORD_WEIGHT=0.3
SQL_ROW_LIMIT=50
SQL_MAX_RETRIES=3
MAX_RESEARCH_LOOPS=4
MAX_REFLECTION_LOOPS=2

# ---- Observability (Langfuse) ---------------------------------------------
# Get keys from a project at https://cloud.langfuse.com (free tier).
# Use the host that matches your project's region:
#   EU: https://cloud.langfuse.com     US: https://us.cloud.langfuse.com
# For a self-hosted local container instead, use http://localhost:3000 + `make up-obs`.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Live-traffic evaluation (daily batch) --------------------------------
LIVE_EVAL_SAMPLE_SIZE=25
LIVE_EVAL_MIN_FAITHFULNESS=0.7
SIM_BASE_URL=http://localhost:8080
