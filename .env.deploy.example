# Copy to .env.deploy and fill in. deploy.sh reads this. NEVER commit .env.deploy.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# optional (tracing) — leave blank to skip
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# cost safety
ALERT_EMAIL=you@example.com
BUDGET_USD=20
# region (optional, defaults us-east-1)
AWS_REGION=us-east-1
